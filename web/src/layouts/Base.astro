---
import { LANGUAGES, DEFAULT_LANG } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}
const {
  title,
  description = '共和曆 — 以西周共和元年為紀元的純太陽曆',
  ogImage,
  ogType = 'website',
  canonicalUrl,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const siteOrigin = new URL(Astro.site ?? 'https://tzengyuxio.github.io').origin;
const siteUrl = `${siteOrigin}${base}`;
const canonical = canonicalUrl ?? `${siteOrigin}${Astro.url.pathname}`;
const ogImg = ogImage ?? `${siteUrl}og-image.png`;
const pageTitle = title.includes('共和曆') ? title : `${title} | 共和曆`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="共和曆" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />

    <title>{pageTitle}</title>

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "共和曆",
      "alternateName": "Gonghe Calendar",
      "url": siteUrl,
      "description": description,
    })} />
    <style>
      :root {
        --color-bg: #0f0f13;
        --color-surface: #1a1a24;
        --color-border: #2a2a38;
        --color-text: #e8e4d9;
        --color-muted: #8a8070;
        --color-accent: #c8a96e;
        --color-accent-dim: #8a7040;
        --color-highlight: #e8c87a;
        --font-sans: 'Noto Sans TC', 'PingFang TC', 'Microsoft JhengHei', system-ui, sans-serif;
        --font-mono: 'Noto Sans Mono', 'Courier New', monospace;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        background: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-sans);
        line-height: 1.7;
        min-height: 100vh;
      }

      a { color: var(--color-accent); text-decoration: none; }
      a:hover { color: var(--color-highlight); text-decoration: underline; }

      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(15, 15, 19, 0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
      }

      .nav-inner {
        max-width: 800px;
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .nav-logo {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--color-accent);
        letter-spacing: 0.05em;
        text-decoration: none;
      }
      .nav-logo:hover { color: var(--color-highlight); text-decoration: none; }

      .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
      }

      .nav-links a {
        color: var(--color-muted);
        font-size: 0.9rem;
        letter-spacing: 0.03em;
        transition: color 0.2s;
      }
      .nav-links a:hover, .nav-links a.active {
        color: var(--color-text);
        text-decoration: none;
      }

      .lang-picker {
        position: relative;
      }
      .lang-btn {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        color: var(--color-muted);
        font-size: 0.82rem;
        font-family: var(--font-sans);
        padding: 0.25rem 0.6rem;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
      }
      .lang-btn:hover, .lang-btn:focus {
        border-color: var(--color-accent-dim);
        color: var(--color-text);
        outline: none;
      }
      .lang-btn svg { transition: transform 0.2s; }
      .lang-picker.open .lang-btn svg { transform: rotate(180deg); }

      .lang-menu {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        right: 0;
        min-width: 180px;
        max-height: 320px;
        overflow-y: auto;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 0.3rem 0;
        list-style: none;
        z-index: 200;
        box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      }
      .lang-picker.open .lang-menu { display: block; }
      .lang-menu li {
        padding: 0.4rem 0.9rem;
        font-size: 0.82rem;
        color: var(--color-text);
        cursor: pointer;
        transition: background 0.15s;
      }
      .lang-menu li:hover { background: rgba(200,169,110,0.1); }
      .lang-menu li.active {
        color: var(--color-highlight);
        font-weight: 600;
      }

      main { min-height: calc(100vh - 120px); }

      footer {
        border-top: 1px solid var(--color-border);
        padding: 1.5rem 0;
        text-align: center;
        color: var(--color-muted);
        font-size: 0.85rem;
      }

      .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .section {
        padding: 3rem 0;
      }

      h1 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.2; }
      h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); line-height: 1.3; }
      h3 { font-size: 1.25rem; }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      th, td {
        border: 1px solid var(--color-border);
        padding: 0.6rem 1rem;
        text-align: left;
      }
      th {
        background: var(--color-surface);
        color: var(--color-accent);
        font-weight: 600;
      }
      tr:nth-child(even) td { background: rgba(26, 26, 36, 0.5); }

      code {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 0.1em 0.4em;
        font-family: var(--font-mono);
        font-size: 0.88em;
        color: var(--color-highlight);
      }

      pre {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 1.5rem;
        overflow-x: auto;
      }
      pre code {
        background: none;
        border: none;
        padding: 0;
      }

    </style>

    <style is:global>
      /* Shared utility classes used across content pages (must be global to reach slotted content) */
      .callout {
        background: rgba(200, 169, 110, 0.08);
        border-left: 3px solid var(--color-accent-dim);
        border-radius: 0 8px 8px 0;
        padding: 1rem 1.5rem;
        margin: 1.5rem 0;
        font-size: 0.92rem;
        color: var(--color-text);
      }

      .highlight-box {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 1rem 1.5rem;
        margin: 1.5rem 0;
      }

      .highlight-row {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--color-border);
        font-size: 0.9rem;
      }
      .highlight-row:last-child { border-bottom: none; }
      .highlight-row .label { color: var(--color-muted); min-width: 140px; }
      .highlight-row .value { color: var(--color-text); font-family: var(--font-mono); }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a class="nav-logo" href={`${base}/`}>共和曆</a>
        <ul class="nav-links">
          <li><a href={`${base}/`}       data-i18n="nav.home">首頁</a></li>
          <li><a href={`${base}/calendar`} data-i18n="nav.calendar">日曆工具</a></li>
          <li><a href={`${base}/rules`}  data-i18n="nav.rules">曆法規則</a></li>
          <li><a href={`${base}/about`}  data-i18n="nav.about">關於</a></li>
        </ul>
        <div class="lang-picker" id="lang-picker">
          <button class="lang-btn" id="lang-btn" type="button" aria-haspopup="listbox" aria-expanded="false">
            <span id="lang-btn-label">{DEFAULT_LANG}</span>
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <ul class="lang-menu" id="lang-menu" role="listbox" aria-label="Select language">
            {LANGUAGES.map(l => <li role="option" data-lang={l.code}>{l.label}</li>)}
          </ul>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">
        <p><span data-i18n="footer.tagline">共和曆 (Gonghe Calendar) · 以西周共和元年（前 841 年）為紀元</span> · <a href="https://github.com/tzengyuxio/gongheli">GitHub</a></p>
        <p style="margin-top:0.5rem; font-size:0.8rem;" data-i18n="footer.quote">聖人慎守日月之數，以察星辰之行，以序四時之順逆，謂之厤 ——《大戴禮記·曾子天圓》</p>
      </div>
    </footer>
  </body>
</html>

<script>
  import { LANGUAGES, DEFAULT_LANG, LANG_KEY, detectLang, t } from '../lib/i18n';
  import type { Lang } from '../lib/i18n';

  function applyLang(lang: Lang) {
    const cfg = LANGUAGES.find(l => l.code === lang);
    document.documentElement.setAttribute('lang', lang);
    document.documentElement.setAttribute('dir', cfg?.dir ?? 'ltr');

    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n')!;
      el.textContent = t(key, lang);
    });

    document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach(el => {
      const key = el.getAttribute('data-i18n-html')!;
      el.innerHTML = t(key, lang);
    });

    window.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
  }

  // Determine initial language:
  // 1. User's explicit choice saved in localStorage
  // 2. Browser/OS locale auto-detection
  // 3. Default language
  const saved = localStorage.getItem(LANG_KEY) as Lang | null;
  const initLang: Lang = saved ?? detectLang() ?? DEFAULT_LANG;

  // Custom language dropdown
  const picker = document.getElementById('lang-picker')!;
  const btn = document.getElementById('lang-btn')!;
  const btnLabel = document.getElementById('lang-btn-label')!;
  const menu = document.getElementById('lang-menu')!;

  function setPickerLabel(lang: Lang) {
    const cfg = LANGUAGES.find(l => l.code === lang);
    btnLabel.textContent = cfg?.label ?? lang;
    menu.querySelectorAll('li').forEach(li => {
      li.classList.toggle('active', li.dataset.lang === lang);
    });
  }

  btn.addEventListener('click', () => {
    picker.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(picker.classList.contains('open')));
  });

  menu.addEventListener('click', (e) => {
    const li = (e.target as HTMLElement).closest('li');
    if (!li?.dataset.lang) return;
    const newLang = li.dataset.lang as Lang;
    localStorage.setItem(LANG_KEY, newLang);
    setPickerLabel(newLang);
    applyLang(newLang);
    picker.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!picker.contains(e.target as Node)) {
      picker.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }
  });

  setPickerLabel(initLang);
  applyLang(initLang);
</script>
