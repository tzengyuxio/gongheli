---
import Base from '../layouts/Base.astro';
---

<Base title="共和曆 — 以共和元年為起點的現代太陽曆" description="共和曆以西周共和元年（前 841 年）為紀元，採用 31/128 閏法精確追蹤回歸年，包含零年設計消除紀年斷層，是一套融合歷史錨點與現代精度的通用太陽曆。">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-brand" data-i18n="index.hero_brand">共和曆</h1>
      <div class="today-badge" data-i18n="index.today_badge">今日</div>
      <div class="today-gonghe" id="today-gonghe">
        <span class="today-loading">計算中…</span>
      </div>
      <div class="today-sub" id="today-sub">
        <span class="today-loading-sub">—</span>
      </div>
      <p class="hero-tagline" data-i18n="index.hero_tagline">一套以人類最古老連續紀年為錨點的通用曆法</p>
    </div>
  </section>

  <!-- Birthday Converter -->
  <section class="section converter-section">
    <div class="container">
      <h2 class="section-title" data-i18n="index.birthday_title">輸入你的生日</h2>
      <div class="converter-box">
        <div class="converter-input">
          <label for="date-input" data-i18n="index.label_gregorian">格里曆日期</label>
          <div class="converter-row">
            <input type="date" id="date-input" value="2000-01-01" />
            <button id="convert-btn" data-i18n="index.btn_convert">換算 →</button>
          </div>
        </div>
        <div class="converter-result" id="converter-result">
          <div class="result-placeholder" data-i18n="index.result_placeholder">← 輸入日期後查看結果</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Features -->
  <section class="section features-section">
    <div class="container">
      <h2 class="section-title" data-i18n="index.why_title">為何選擇共和曆？</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3 data-i18n="index.feature1_title">精確 150 倍</h3>
          <p data-i18n="index.feature1_desc">31/128 閏法，每年誤差僅 0.2 秒，比格里曆（97/400 規則，26 秒/年）精確 150 倍。約 400,000 年才累積一天的偏差。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">∅</div>
          <h3 data-i18n="index.feature2_title">零年設計</h3>
          <p data-i18n="index.feature2_desc">共和 0 年存在，數學上完整無缺。消除了公元紀年「西元 1 年之前是西元前 1 年，沒有西元 0 年」的計算陷阱。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🏛</div>
          <h3><span id="current-year-feature">2866</span><span data-i18n="index.feature3_title_suffix"> 年紀年</span></h3>
          <p id="feature3-desc">以西周共和元年（西元前 841 年）為紀元——人類歷史上最早有連續年份記載的紀年。今年是共和 <span id="current-year-feature2">2866</span> 年。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Historical Events -->
  <section class="section events-section">
    <div class="container">
      <h2 class="section-title" data-i18n="index.events_title">歷史在共和曆中</h2>
      <div class="events-grid" id="events-grid">
        <!-- filled by JS -->
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    background: radial-gradient(ellipse at 50% 40%, rgba(200, 169, 110, 0.08) 0%, transparent 70%);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    padding: 3rem 1.5rem 2.5rem;
  }
  .hero .container {
    max-width: 520px;
  }

  .hero-brand {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .today-badge {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid var(--color-accent-dim);
    border-radius: 20px;
    padding: 0.15rem 0.75rem;
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .today-gonghe {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700;
    color: var(--color-highlight);
    letter-spacing: 0.02em;
    margin-bottom: 0.35rem;
    line-height: 1.2;
  }

  .today-sub {
    font-size: 0.9rem;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
    letter-spacing: 0.03em;
  }

  .hero-tagline {
    font-size: clamp(0.85rem, 2vw, 0.95rem);
    color: var(--color-muted);
    margin: 0 auto;
    font-style: italic;
  }

  .today-loading { color: var(--color-muted); font-size: 1.2rem; font-weight: 400; }
  .today-loading-sub { color: var(--color-muted); }

  /* Section common */
  .section-title {
    text-align: center;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    font-size: 1.2rem;
  }

  /* Converter */
  .converter-section { background: var(--color-surface); }
  .converter-box {
    max-width: 440px;
    margin: 0 auto;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
  }

  .converter-input label {
    display: block;
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .converter-row {
    display: flex;
    gap: 0.5rem;
  }

  .converter-input input[type="date"] {
    flex: 1;
    min-width: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.45rem 0.75rem;
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: var(--font-mono);
    outline: none;
    transition: border-color 0.2s;
  }
  .converter-input input[type="date"]:focus {
    border-color: var(--color-accent-dim);
  }

  .converter-input button {
    flex-shrink: 0;
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    padding: 0.45rem 1rem;
    color: var(--color-highlight);
    font-size: 0.88rem;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .converter-input button:hover {
    background: var(--color-accent);
    color: #1a1a24;
  }

  .converter-result {
    margin-top: 1rem;
    text-align: center;
  }
  .result-placeholder {
    color: var(--color-muted);
    font-size: 0.85rem;
    padding: 0.5rem 0;
  }
  .result-date { text-align: center; }
  .result-year {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-highlight);
    line-height: 1.3;
  }
  .result-meta {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-top: 0.4rem;
  }
  .result-meta span {
    display: inline-block;
    margin: 0.15rem 0.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 0.05rem 0.6rem;
    font-size: 0.78rem;
  }
  .result-zdn {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 0.3rem;
    font-family: var(--font-mono);
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 700px) {
    .features-grid { grid-template-columns: 1fr; }
  }
  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }
  .feature-card:hover {
    border-color: var(--color-accent-dim);
  }
  .feature-icon {
    font-size: 1.5rem;
    margin-bottom: 0.6rem;
    line-height: 1;
  }
  .feature-card h3 {
    color: var(--color-highlight);
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }
  .feature-card p {
    color: var(--color-text);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Events */
  .events-section { background: var(--color-surface); }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 700px) {
    .events-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .events-grid { grid-template-columns: 1fr; }
  }
  .event-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .event-name { font-weight: 600; color: var(--color-text); font-size: 0.88rem; }
  .event-gregorian { color: var(--color-muted); font-size: 0.78rem; font-family: var(--font-mono); }
  .event-gonghe { color: var(--color-accent); font-size: 0.9rem; font-family: var(--font-mono); }
  .event-meta { color: var(--color-muted); font-size: 0.75rem; }
</style>

<script>
  import { getTodayGonghe, getGongheDateFromGregorian, formatGregorianDate } from '../lib/gonghe.ts';
  import { t, fmt, DEFAULT_LANG, LANG_KEY } from '../lib/i18n';
  import type { Lang } from '../lib/i18n';

  const getLang = (): Lang => (localStorage.getItem(LANG_KEY) as Lang) ?? DEFAULT_LANG;

  const today = getTodayGonghe();

  // Pre-compute Gonghe dates for events (pure math, values never change)
  const EVENTS = [
    { key: 'event.apollo',     year: 1969, month: 7,  day: 20 },
    { key: 'event.french_rev', year: 1789, month: 7,  day: 14 },
    { key: 'event.newton',     year: 1643, month: 1,  day: 4  },
    { key: 'event.ww1_end',    year: 1918, month: 11, day: 11 },
    { key: 'event.un',         year: 1945, month: 10, day: 24 },
    { key: 'event.genome',     year: 2003, month: 4,  day: 14 },
  ] as const;
  const EVENTS_COMPUTED = EVENTS.map(ev => ({
    ...ev,
    gonghe:    getGongheDateFromGregorian(ev.year, ev.month, ev.day),
    gregorian: formatGregorianDate(ev.year, ev.month, ev.day),
  }));

  // --- Today widget ---
  const ghEl = document.getElementById('today-gonghe')!;
  const subEl = document.getElementById('today-sub')!;

  function renderToday() {
    const lang = getLang();
    ghEl.innerHTML = fmt('fmt.gonghe_date', lang, { year: today.year, month: today.month, day: today.day });
    subEl.innerHTML = fmt('fmt.today_sub', lang, {
      ganzhi: today.ganzhiStr, weekday: today.weekdayStr,
      year: today.year, month: today.month, day: today.day,
    });
  }
  renderToday();

  // --- Converter ---
  const inputEl = document.getElementById('date-input') as HTMLInputElement;
  const resultEl = document.getElementById('converter-result')!;
  const btnEl = document.getElementById('convert-btn')!;

  function convertDate() {
    const val = inputEl.value;
    if (!val) return;
    const lang = getLang();
    const [y, m, d] = val.split('-').map(Number);
    const r = getGongheDateFromGregorian(y, m, d);
    resultEl.innerHTML = `
      <div class="result-date">
        <div class="result-year">${fmt('fmt.gonghe_date', lang, { year: r.year, month: r.month, day: r.day })}</div>
        <div class="result-meta">
          <span>${r.ganzhiStr}日</span>
          <span>${r.weekdayStr}</span>
        </div>
        <div class="result-zdn">子輿日 ZDN ${r.zdn.toLocaleString()}</div>
      </div>
    `;
  }

  btnEl.addEventListener('click', convertDate);
  inputEl.addEventListener('change', convertDate);
  convertDate();

  // --- Feature 3 dynamic year ---
  function renderFeature3() {
    const lang = getLang();
    const yearEl = document.getElementById('current-year-feature');
    const yearEl2 = document.getElementById('current-year-feature2');
    const descEl = document.getElementById('feature3-desc');
    if (yearEl) yearEl.textContent = String(today.year);
    if (yearEl2) yearEl2.textContent = String(today.year);
    if (descEl) descEl.textContent = fmt('index.feature3_desc', lang, { year: today.year });
  }
  renderFeature3();

  // --- Historical events ---
  const eventsEl = document.getElementById('events-grid')!;

  function renderEvents() {
    const lang = getLang();
    eventsEl.innerHTML = EVENTS_COMPUTED.map(ev => `
      <div class="event-card">
        <div class="event-name">${t(ev.key, lang)}</div>
        <div class="event-gregorian">${fmt('fmt.event_gregorian', lang, { date: ev.gregorian })}</div>
        <div class="event-gonghe">${fmt('fmt.gonghe_date', lang, { year: ev.gonghe.year, month: ev.gonghe.month, day: ev.gonghe.day })}</div>
        <div class="event-meta">${ev.gonghe.ganzhiStr}日 · ${ev.gonghe.weekdayStr}</div>
      </div>
    `).join('');
  }
  renderEvents();

  window.addEventListener('langchange', () => {
    renderToday();
    convertDate();
    renderFeature3();
    renderEvents();
  });
</script>
