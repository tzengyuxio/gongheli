---
import Base from '../layouts/Base.astro';
---

<Base title="共和曆 — 以共和元年為起點的現代太陽曆" description="共和曆以西周共和元年（前 841 年）為紀元，採用 31/128 閏法精確追蹤回歸年，包含零年設計消除紀年斷層，是一套融合歷史錨點與現代精度的通用太陽曆。">
  <!-- Hero: Today's Date -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="hero-badge" data-i18n="index.today_badge">今日</div>
      <div class="hero-date">
        <div class="hero-year" id="today-year">
          <span class="hero-loading">...</span>
        </div>
        <div class="hero-monthday" id="today-date"></div>
      </div>
      <div class="hero-meta" id="today-sub">—</div>
      <p class="hero-tagline" data-i18n="index.hero_tagline">
        一套以人類最古老連續紀年為錨點的通用曆法
      </p>
    </div>
  </section>

  <!-- Birthday Converter (moved from hero) -->
  <section class="section converter-section">
    <div class="container narrow">
      <h2 class="converter-title" data-i18n="index.birthday_title">看看我的共和曆生日</h2>
      <div class="converter-box">
        <div class="converter-input">
          <label for="date-input" data-i18n="index.label_gregorian">格里曆日期</label>
          <input type="date" id="date-input" value="2000-01-01" />
        </div>
        <div class="converter-result" id="converter-result">
          <div class="result-placeholder" data-i18n="index.result_placeholder">輸入日期查看結果</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Six Features -->
  <section class="section features-section fade-in">
    <div class="container">
      <h2 class="section-title" data-i18n="index.why_title">為何選擇共和曆？</h2>
      <div class="features-grid stagger">
        <div class="feature-card">
          <div class="feature-icon">🏛</div>
          <h3><span id="current-year-feature">2866</span><span data-i18n="index.feature_epoch_title_suffix"> 年紀年</span></h3>
          <p id="feature-epoch-desc">以西周共和元年（西元前 841 年）為紀元——人類歷史上最早有連續年份記載的紀年。今年是共和 <span id="current-year-feature2">2866</span> 年。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3 data-i18n="index.feature_accuracy_title">精確 150 倍</h3>
          <p data-i18n="index.feature_accuracy_desc">128 年 31 閏，每年誤差僅 0.2 秒，比格里曆（400 年 97 閏，26 秒/年）精確 150 倍。約 400,000 年才累積一天的偏差。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">∅</div>
          <h3 data-i18n="index.feature_zero_title">零年設計</h3>
          <p data-i18n="index.feature_zero_desc">共和 0 年存在，數學上完整無缺。消除了公元紀年「西元 1 年之前是西元前 1 年，沒有西元 0 年」的計算陷阱。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📅</div>
          <h3 data-i18n="index.feature_months_title">簡明月制</h3>
          <p data-i18n="index.feature_months_desc">單數月 30 天、偶數月 31 天，規律易記。不像格里曆月長忽大忽小（28/30/31），需要口訣才能記住。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📌</div>
          <h3 data-i18n="index.feature_leapend_title">閏日置年末</h3>
          <p data-i18n="index.feature_leapend_desc">閏日放在 12 月末，1 至 11 月的日期與星期對應每年固定。格里曆閏日在 2 月，導致 3 月之後的日期在閏年與平年之間錯位一天。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔄</div>
          <h3 data-i18n="index.feature_ji_title">一紀 4418 年</h3>
          <p data-i18n="index.feature_ji_desc">回歸年、朔望月、干支甲子、七曜週的近似最小公倍數週期。以天文實測的「朔旦冬至甲子日」為錨點，曆法與天文精確對齊。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Historical Events -->
  <section class="section events-section fade-in">
    <div class="container narrow">
      <h2 class="section-title" data-i18n="index.events_title">歷史在共和曆中</h2>
      <div class="timeline" id="events-grid">
        <!-- filled by JS -->
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 2rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(180, 160, 120, 0.06) 0%, transparent 70%),
      radial-gradient(circle at 30% 70%, rgba(100, 90, 70, 0.04) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    animation: heroFadeIn 1.2s var(--ease-out) both;
  }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dim);
    border-radius: 20px;
    padding: 0.2rem 1rem;
    margin-bottom: 1.5rem;
  }

  .hero-date {
    margin-bottom: 0.5rem;
  }

  .hero-year {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    color: var(--color-highlight);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .hero-monthday {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    color: var(--color-accent-bright);
    line-height: 1.2;
    margin-top: 0.25rem;
  }

  .hero-meta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 1rem;
    letter-spacing: 0.05em;
  }

  .hero-tagline {
    font-size: 0.95rem;
    color: var(--color-text-dim);
    margin-top: 2rem;
    font-style: italic;
    font-family: var(--font-display);
  }

  .hero-loading {
    color: var(--color-text-dim);
    font-size: 2rem;
    font-weight: 400;
  }

  @media (max-width: 700px) {
    .hero { min-height: 50vh; padding: 3rem 1.5rem; }
  }

  /* Converter Section */
  .converter-section {
    border-bottom: 1px solid var(--color-border);
  }

  .converter-title {
    text-align: center;
    font-family: var(--font-display);
    color: var(--color-highlight);
    margin-bottom: 1.5rem;
    font-size: 1.3rem;
  }

  .converter-box {
    max-width: 400px;
    margin: 0 auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.5rem;
  }

  .converter-input label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .converter-input input[type="date"] {
    width: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: var(--font-mono);
    outline: none;
    transition: border-color 0.2s;
  }
  .converter-input input[type="date"]:focus {
    border-color: var(--color-accent-dim);
  }

  .converter-result {
    margin-top: 1.25rem;
    text-align: center;
  }

  .result-placeholder {
    color: var(--color-muted);
    font-size: 0.85rem;
    padding: 0.5rem 0;
  }

  /* Converter results are JS-generated; use :global() */
  :global(.result-date) { text-align: center; }
  :global(.result-year) {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--color-highlight);
    line-height: 1.3;
  }
  :global(.result-meta) {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-top: 0.35rem;
  }
  :global(.result-meta span) {
    display: inline-block;
    margin: 0.1rem 0.2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 0.05rem 0.5rem;
    font-size: 0.75rem;
  }
  :global(.result-zdn) {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 0.3rem;
    font-family: var(--font-mono);
  }

  /* Section common */
  .section-title {
    text-align: center;
    font-family: var(--font-display);
    color: var(--color-highlight);
    margin-bottom: 1.5rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .features-grid { grid-template-columns: 1fr; }
  }
  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .feature-card:hover {
    border-color: var(--color-accent-dim);
    box-shadow: 0 0 24px rgba(180, 160, 120, 0.08);
  }
  .feature-icon {
    font-size: 1.8rem;
    margin-bottom: 0.6rem;
    line-height: 1;
  }
  .feature-card h3 {
    color: var(--color-highlight);
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }
  .feature-card p {
    color: var(--color-text);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Events Timeline */
  .events-section {
    background: var(--color-surface);
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--color-accent-dim), transparent);
  }

  :global(.timeline-item) {
    position: relative;
    padding: 0 0 1.25rem 1.5rem;
  }

  :global(.timeline-dot) {
    position: absolute;
    left: -2rem;
    top: 0.55rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translateX(calc(-50% + 0.5px));
  }

  :global(.timeline-content) {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.9rem 1.2rem;
    transition: border-color 0.2s;
  }
  :global(.timeline-content:hover) {
    border-color: var(--color-accent-dim);
  }

  :global(.event-name) {
    font-weight: 600;
    color: var(--color-highlight);
    font-size: 0.92rem;
    margin-bottom: 0.25rem;
  }

  :global(.event-dates) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    flex-wrap: wrap;
  }

  :global(.event-gregorian) {
    color: var(--color-muted);
  }

  :global(.event-arrow) {
    color: var(--color-accent-dim);
    font-size: 0.75rem;
  }

  :global(.event-gonghe) {
    color: var(--color-accent);
  }

  :global(.event-meta) {
    color: var(--color-muted);
    font-size: 0.75rem;
    margin-top: 0.2rem;
  }

  @media (max-width: 500px) {
    .timeline { padding-left: 1.5rem; }
    :global(.timeline-item) { padding-left: 1rem; }
  }
</style>

<script>
  import { getTodayGonghe, getGongheDateFromGregorian, formatGregorianDate } from '../lib/gonghe.ts';
  import { t, fmt, getLang, weekdayI18n } from '../lib/i18n';

  const today = getTodayGonghe();

  // Pre-compute Gonghe dates for events (pure math, values never change)
  const ALL_EVENTS = [
    { key: 'event.apollo',          year: 1969, month: 7,  day: 20 },
    { key: 'event.french_rev',      year: 1789, month: 7,  day: 14 },
    { key: 'event.newton',          year: 1643, month: 1,  day: 4  },
    { key: 'event.ww1_end',         year: 1918, month: 11, day: 11 },
    { key: 'event.un',              year: 1945, month: 10, day: 24 },
    { key: 'event.genome',          year: 2003, month: 4,  day: 14 },
    { key: 'event.berlin_wall',     year: 1989, month: 11, day: 9  },
    { key: 'event.columbus',        year: 1492, month: 10, day: 12 },
    { key: 'event.magna_carta',     year: 1215, month: 6,  day: 15 },
    { key: 'event.declaration',     year: 1776, month: 7,  day: 4  },
    { key: 'event.wright',          year: 1903, month: 12, day: 17 },
    { key: 'event.constantinople',  year: 1453, month: 5,  day: 29 },
    { key: 'event.luther',          year: 1517, month: 10, day: 31 },
    { key: 'event.gagarin',         year: 1961, month: 4,  day: 12 },
    { key: 'event.telephone',       year: 1876, month: 3,  day: 7  },
    { key: 'event.versailles',      year: 1919, month: 6,  day: 28 },
    { key: 'event.copernicus',      year: 1543, month: 5,  day: 24 },
    { key: 'event.vaccine',         year: 1796, month: 5,  day: 14 },
    { key: 'event.eniac',           year: 1946, month: 2,  day: 14 },
    { key: 'event.www',             year: 1991, month: 8,  day: 6  },
    { key: 'event.sputnik',         year: 1957, month: 10, day: 4  },
    { key: 'event.waterloo',        year: 1815, month: 6,  day: 18 },
    { key: 'event.darwin',          year: 1859, month: 11, day: 24 },
    { key: 'event.galileo',         year: 1610, month: 1,  day: 7  },
    { key: 'event.magellan',        year: 1522, month: 9,  day: 6  },
    { key: 'event.ww2_end',         year: 1945, month: 9,  day: 2  },
    { key: 'event.penicillin',      year: 1928, month: 9,  day: 28 },
    { key: 'event.gutenberg',       year: 1455, month: 2,  day: 23 },
    { key: 'event.zheng_he',        year: 1405, month: 7,  day: 11 },
    { key: 'event.meiji',           year: 1868, month: 1,  day: 3  },
  ] as const;
  const ALL_EVENTS_COMPUTED = ALL_EVENTS.map(ev => ({
    ...ev,
    gonghe:    getGongheDateFromGregorian(ev.year, ev.month, ev.day),
    gregorian: formatGregorianDate(ev.year, ev.month, ev.day),
  }));

  // Fisher-Yates shuffle, then pick first N
  function pickRandom<T>(arr: T[], n: number): T[] {
    const shuffled = [...arr];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled.slice(0, n);
  }

  let displayedEvents = pickRandom(ALL_EVENTS_COMPUTED, 6);

  // --- Today widget ---
  const yearEl = document.getElementById('today-year')!;
  const dateEl = document.getElementById('today-date')!;
  const subEl = document.getElementById('today-sub')!;

  function renderToday() {
    const lang = getLang();
    yearEl.textContent = fmt('fmt.gonghe_year', lang, { year: today.year });
    dateEl.textContent = fmt('fmt.gonghe_md', lang, { month: today.month, day: today.day });
    const isoDate = `${today.year}-${String(today.month).padStart(2, '0')}-${String(today.day).padStart(2, '0')}`;
    subEl.innerHTML = fmt('fmt.today_sub', lang, {
      ganzhi: today.ganzhiStr, weekday: weekdayI18n(today.weekdayIdx, lang),
      date: isoDate,
    });
  }
  renderToday();

  // --- Converter ---
  const inputEl = document.getElementById('date-input') as HTMLInputElement;
  const resultEl = document.getElementById('converter-result')!;

  function convertDate() {
    const val = inputEl.value;
    if (!val) return;
    const lang = getLang();
    const [y, m, d] = val.split('-').map(Number);
    const r = getGongheDateFromGregorian(y, m, d);
    resultEl.innerHTML = `
      <div class="result-date">
        <div class="result-year">${fmt('fmt.gonghe_date', lang, { year: r.year, month: r.month, day: r.day })}</div>
        <div class="result-meta">
          <span>${r.ganzhiStr}日</span>
          <span>${weekdayI18n(r.weekdayIdx, lang)}</span>
        </div>
        <div class="result-zdn">子輿日 ZDN ${r.zdn.toLocaleString()}</div>
      </div>
    `;
  }

  inputEl.addEventListener('input', convertDate);
  convertDate();

  // --- Feature: epoch dynamic year ---
  function renderFeatureEpoch() {
    const lang = getLang();
    const yearEl = document.getElementById('current-year-feature');
    const yearEl2 = document.getElementById('current-year-feature2');
    const descEl = document.getElementById('feature-epoch-desc');
    if (yearEl) yearEl.textContent = String(today.year);
    if (yearEl2) yearEl2.textContent = String(today.year);
    if (descEl) descEl.textContent = fmt('index.feature_epoch_desc', lang, { year: today.year });
  }
  renderFeatureEpoch();

  // --- Historical events ---
  const eventsEl = document.getElementById('events-grid')!;

  function renderEvents() {
    const lang = getLang();
    eventsEl.innerHTML = displayedEvents.map(ev => `
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="event-name">${t(ev.key, lang)}</div>
          <div class="event-dates">
            <span class="event-gregorian">${fmt('fmt.event_gregorian', lang, { date: ev.gregorian })}</span>
            <span class="event-arrow">&rarr;</span>
            <span class="event-gonghe">${fmt('fmt.gonghe_date', lang, { year: ev.gonghe.year, month: ev.gonghe.month, day: ev.gonghe.day })}</span>
          </div>
          <div class="event-meta">${ev.gonghe.ganzhiStr}日 · ${weekdayI18n(ev.gonghe.weekdayIdx, lang)}</div>
        </div>
      </div>
    `).join('');
  }
  renderEvents();

  window.addEventListener('langchange', () => {
    renderToday();
    convertDate();
    renderFeatureEpoch();
    renderEvents();
  });
</script>
