---
import Base from '../layouts/Base.astro';
---

<Base title="日曆工具" description="共和曆與格里曆雙向轉換工具">
  <div class="container section">
    <h1 data-i18n="calendar.title">日曆工具</h1>

    <div class="converter-grid">
      <!-- Gregorian to Gonghe -->
      <div class="conv-panel">
        <h2 data-i18n="calendar.panel1_title">格里曆 → 共和曆</h2>
        <div class="field-group">
          <label data-i18n="calendar.label_gregorian">格里曆日期</label>
          <input type="date" id="g2gh-input" value="2000-01-01" />
        </div>
        <button id="g2gh-btn" data-i18n="calendar.btn_convert">轉換 →</button>
        <div class="result-panel" id="g2gh-result"></div>
      </div>

      <!-- Gonghe to Gregorian -->
      <div class="conv-panel">
        <h2 data-i18n="calendar.panel2_title">共和曆 → 格里曆</h2>
        <div class="field-row">
          <div class="field-group">
            <label data-i18n="calendar.label_year">年</label>
            <input type="number" id="gh2g-year" value="2841" min="-9999" max="9999" />
          </div>
          <div class="field-group">
            <label data-i18n="calendar.label_month">月</label>
            <input type="number" id="gh2g-month" value="1" min="1" max="12" />
          </div>
          <div class="field-group">
            <label data-i18n="calendar.label_day">日</label>
            <input type="number" id="gh2g-day" value="13" min="1" max="31" />
          </div>
        </div>
        <button id="gh2g-btn" data-i18n="calendar.btn_convert">轉換 →</button>
        <div class="result-panel" id="gh2g-result"></div>
      </div>
    </div>

    <!-- Today quick reference -->
    <div class="today-ref" id="today-ref"></div>
  </div>
</Base>

<style>
  .converter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 700px) {
    .converter-grid { grid-template-columns: 1fr; }
  }

  .conv-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
  }
  .conv-panel h2 {
    font-size: 1rem;
    color: var(--color-highlight);
    margin-bottom: 1rem;
  }

  .field-group {
    margin-bottom: 0.75rem;
  }
  .field-group label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.3rem;
  }
  .field-group input {
    width: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.45rem 0.75rem;
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: var(--font-mono);
    outline: none;
    transition: border-color 0.2s;
  }
  .field-group input:focus { border-color: var(--color-accent-dim); }

  .field-row {
    display: grid;
    grid-template-columns: 5rem 3.5rem 3.5rem;
    gap: 0.5rem;
  }

  button {
    width: 100%;
    background: var(--color-accent-dim);
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    padding: 0.45rem;
    color: var(--color-highlight);
    font-size: 0.88rem;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: background 0.2s;
    margin-bottom: 1rem;
  }
  button:hover { background: var(--color-accent); color: #1a1a24; }

  .result-panel {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Unified result card used in both converter panels and today-ref */
  .result-card {
    text-align: center;
    width: 100%;
  }
  .result-date {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-highlight);
    margin-bottom: 0.3rem;
  }
  .result-details {
    font-size: 0.8rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .result-details .sep,
  .today-ref .sep {
    margin: 0 0.25rem;
    opacity: 0.4;
  }
  .result-zdn {
    font-size: 0.75rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    margin-top: 0.3rem;
  }

  .today-ref {
    background: var(--color-surface);
    border: 1px solid var(--color-accent-dim);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    text-align: center;
  }
  .today-ref-label {
    font-size: 0.72rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }
</style>

<script>
  import {
    formatGregorianDate,
    getGongheDateFromGregorian,
    getTodayGonghe,
    getTodayGregorianString,
    gongheToGregorian,
    gongheToZiyu,
    ganzhiIndex,
    ganzhiName,
    weekday,
    isLeapYear,
  } from '../lib/gonghe.ts';
  import { t, fmt, getLang, weekdayI18n } from '../lib/i18n';

  // Shared result card renderer
  function renderResultCard(title: string, details: string[], zdn: number): string {
    const sep = '<span class="sep">·</span>';
    return `
      <div class="result-card">
        <div class="result-date">${title}</div>
        <div class="result-details">${details.join(sep)}</div>
        <div class="result-zdn">ZDN ${zdn.toLocaleString()}</div>
      </div>`;
  }

  // --- G2GH ---
  const g2ghInput = document.getElementById('g2gh-input') as HTMLInputElement;
  const g2ghResult = document.getElementById('g2gh-result')!;
  const g2ghBtn = document.getElementById('g2gh-btn')!;

  function doG2GH() {
    const val = g2ghInput.value;
    if (!val) return;
    const lang = getLang();
    const [y, m, d] = val.split('-').map(Number);
    const r = getGongheDateFromGregorian(y, m, d);
    const leapMark = isLeapYear(r.year) ? t('result.leap', lang) : t('result.common', lang);
    g2ghResult.innerHTML = renderResultCard(
      fmt('fmt.gonghe_date', lang, { year: r.year, month: r.month, day: r.day }),
      [`${r.year} ${leapMark}`, fmt('fmt.ganzhi_idx', lang, { ganzhi: r.ganzhiStr, idx: r.ganzhiIdx + 1 }), weekdayI18n(r.weekdayIdx, lang)],
      r.zdn,
    );
  }

  g2ghBtn.addEventListener('click', doG2GH);
  g2ghInput.addEventListener('change', doG2GH);
  doG2GH();

  // --- GH2G ---
  const gh2gYear = document.getElementById('gh2g-year') as HTMLInputElement;
  const gh2gMonth = document.getElementById('gh2g-month') as HTMLInputElement;
  const gh2gDay = document.getElementById('gh2g-day') as HTMLInputElement;
  const gh2gResult = document.getElementById('gh2g-result')!;
  const gh2gBtn = document.getElementById('gh2g-btn')!;

  function doGH2G() {
    const y = parseInt(gh2gYear.value);
    const m = parseInt(gh2gMonth.value);
    const d = parseInt(gh2gDay.value);
    if (isNaN(y) || isNaN(m) || isNaN(d)) return;
    const lang = getLang();
    const [gy, gm, gd] = gongheToGregorian(y, m, d);
    const zdn = gongheToZiyu(y, m, d);
    const gzIdx = ganzhiIndex(zdn);
    const wdIdx = weekday(zdn);
    const gregFmt = gy >= 1
      ? fmt('fmt.gregorian_ce', lang, { year: gy, month: gm, day: gd })
      : fmt('fmt.gregorian_bce', lang, { year: -gy, month: gm, day: gd });
    gh2gResult.innerHTML = renderResultCard(
      gregFmt,
      [fmt('fmt.ganzhi_idx', lang, { ganzhi: ganzhiName(gzIdx), idx: gzIdx + 1 }), weekdayI18n(wdIdx, lang)],
      zdn,
    );
  }

  gh2gBtn.addEventListener('click', doGH2G);
  doGH2G();

  // --- Today reference ---
  const today = getTodayGonghe();
  const gregStr = getTodayGregorianString();
  const todayRef = document.getElementById('today-ref')!;

  function renderTodayRef() {
    const lang = getLang();
    todayRef.innerHTML = `
      <div class="today-ref-label">${t('calendar.today_title', lang)}</div>` +
      renderResultCard(
        fmt('fmt.gonghe_date', lang, { year: today.year, month: today.month, day: today.day }),
        [gregStr, `${today.ganzhiStr}日`, weekdayI18n(today.weekdayIdx, lang)],
        today.zdn,
      );
  }
  renderTodayRef();

  window.addEventListener('langchange', () => {
    doG2GH();
    doGH2G();
    renderTodayRef();
  });
</script>
